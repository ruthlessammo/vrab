[Unit]
Description=VRAB Trading Engine
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=will
WorkingDirectory=/home/will/vrab
EnvironmentFile=/home/will/vrab/.env
ExecStart=/usr/bin/python3 -m live.engine
Restart=on-failure
RestartSec=10
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
